<div class="page-header">
  <div>
    <h1><%= @project.name %> — Sprints</h1>
  </div>
  <div class="page-header-actions">
    <%= link_to "← Project", project_path(@project), class: "btn" %>
    <%= link_to "New Sprint", new_project_sprint_path(@project), class: "btn accent" %>
  </div>
</div>

<% if @sprints.empty? %>
  <p class="text-muted" style="text-align: center; padding: 40px;">No sprints yet. Create one to start planning.</p>
<% else %>
  <% @sprints.each do |sprint| %>
    <div class="sprint-card">
      <div class="sprint-card-header">
        <div>
          <h3 style="margin-bottom: 4px;"><%= link_to sprint.name, sprint_path(sprint) %></h3>
          <p class="text-muted"><%= sprint.goal %></p>
        </div>
        <div style="display: flex; align-items: center; gap: 8px;">
          <span class="sprint-badge <%= sprint.status %>"><%= sprint.status.titleize %></span>
          <%= link_to "View", sprint_path(sprint), class: "btn" %>
        </div>
      </div>
      <div style="display: flex; gap: 24px; font-size: 10px; color: var(--wire-dark);">
        <span><%= sprint.issues.count %> issues</span>
        <% if sprint.start_date %>
          <span><%= sprint.start_date.strftime("%b %d") %> – <%= sprint.end_date&.strftime("%b %d") %></span>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

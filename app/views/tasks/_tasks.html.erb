<div class="tasks-section" style="margin-top: 30px; padding: 20px; background: var(--ghost); border-radius: 8px;">
  <h3 style="margin-bottom: 16px;">Checklist</h3>

  <div class="tasks-list" style="margin-bottom: 20px;">
    <% @issue.tasks.ordered.each do |task| %>
      <div class="task-item" style="display: flex; align-items: center; padding: 12px; border-bottom: 1px solid rgba(26,26,26,0.1); gap: 12px;">
        <form action="<%= issue_task_toggle_path(@issue, task) %>" method="post" style="margin: 0;">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <input type="hidden" name="_method" value="patch">
          <input type="checkbox" <%= 'checked' if task.completed? %> onchange="this.form.submit();" 
                 style="width: 20px; height: 20px; cursor: pointer;">
        </form>

        <span style="flex: 1; <%= 'text-decoration: line-through; color: #999;' if task.completed? %>">
          <%= task.title %>
        </span>

        <div style="display: flex; gap: 8px;">
          <%= link_to 'Edit', edit_issue_task_path(@issue, task), class: 'btn btn-sm' %>
          <%= link_to 'Delete', issue_task_path(@issue, task), data: { turbo_method: :delete, turbo_confirm: 'Sure?' }, class: 'btn btn-sm btn-danger' %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="new-task-form" style="padding-top: 12px; border-top: 1px solid rgba(26,26,26,0.1);">
    <form action="<%= issue_tasks_path(@issue) %>" method="post" class="form" style="display: flex; gap: 8px;">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
      
      <input type="text" name="task[title]" placeholder="Add a new task..." class="form-input" style="flex: 1;">
      <button type="submit" class="btn btn-primary">Add</button>
    </form>
  </div>
</div>

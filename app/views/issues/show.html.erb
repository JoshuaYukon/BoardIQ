<div class="page-header">
  <div>
    <h1><%= @issue.title %></h1>
    <div class="board-breadcrumb" style="margin-top: 8px;">
      <%= link_to @issue.project.name, project_path(@issue.project) %>
      <span style="color: var(--wire-dark);">/</span>
      <%= link_to @issue.board.name, board_path(@issue.board) %>
      <span style="color: var(--wire-dark);">/</span>
      <span style="color: var(--ink); font-weight: 600;"><%= @issue.title %></span>
    </div>
  </div>
  <div class="page-header-actions">
    <%= link_to "Edit", edit_issue_path(@issue), class: "btn" %>
    <%= link_to "Delete", @issue, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn danger" %>
  </div>
</div>

<div style="max-width: 1000px; display: grid; grid-template-columns: 1fr 280px; gap: 24px;">
  <!-- Main content -->
  <div>
    <!-- Description -->
    <div class="form-group">
      <label style="font-size: 10px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--wire-dark);">Description</label>
      <div style="background: #faf8f4; border: 1.5px solid var(--wire); border-radius: 2px; padding: 12px; margin-top: 6px;">
        <div style="font-size: 11px; line-height: 1.6;"><%= @issue.description %></div>
      </div>
    </div>

    <!-- Attachments -->
    <% if @issue.attachments.attached? %>
      <div style="margin-bottom: 20px;">
        <div style="font-size: 10px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--wire-dark); margin-bottom: 10px;">
          Attachments (<%= @issue.attachments.count %>)
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 10px;">
          <% @issue.attachments.each do |attachment| %>
            <% if attachment.content_type.start_with?("image/") %>
              <a href="<%= rails_blob_path(attachment, disposition: 'attachment') %>" target="_blank" style="display: block; border: 1.5px solid var(--wire); border-radius: 2px; overflow: hidden; flex-shrink: 0;">
                <%= image_tag rails_blob_path(attachment, disposition: "inline"),
                      style: "width: 120px; height: 90px; object-fit: cover; display: block;",
                      title: attachment.filename %>
              </a>
            <% elsif attachment.content_type.start_with?("video/") %>
              <div style="border: 1.5px solid var(--wire); border-radius: 2px; overflow: hidden; flex-shrink: 0;">
                <video controls style="width: 240px; height: 160px; display: block; background: #000;">
                  <source src="<%= rails_blob_path(attachment, disposition: 'inline') %>" type="<%= attachment.content_type %>">
                </video>
                <div style="padding: 4px 8px; font-size: 10px; color: var(--wire-dark); background: var(--paper2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 240px;"><%= attachment.filename %></div>
              </div>
            <% else %>
              <a href="<%= rails_blob_path(attachment, disposition: 'attachment') %>"
                 style="display: flex; align-items: center; gap: 8px; border: 1.5px solid var(--wire); border-radius: 2px; padding: 10px 14px; background: var(--paper2); text-decoration: none; color: var(--ink); font-size: 11px; min-width: 160px;">
                <span style="font-size: 20px;">📎</span>
                <div style="overflow: hidden;">
                  <div style="font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px;"><%= attachment.filename %></div>
                  <div style="font-size: 10px; color: var(--wire-dark);"><%= number_to_human_size(attachment.byte_size) %></div>
                </div>
              </a>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Status Chips -->
    <div style="display: flex; gap: 8px; flex-wrap: wrap; margin: 20px 0;">
      <div style="display: inline-flex; align-items: center; gap: 6px; background: var(--paper2); border: 1.5px solid var(--wire); border-radius: 2px; padding: 6px 12px;">
        <% status_color = case @issue.status
          when Issue::STATUSES[:todo] then 'var(--accent)'
          when Issue::STATUSES[:in_progress] then 'var(--blue)'
          when Issue::STATUSES[:done] then 'var(--accent2)'
        end %>
        <div style="width: 8px; height: 8px; border-radius: 50%; background: <%= status_color %>;"></div>
        <span style="font-size: 10px; font-weight: 600;"><%= @issue.status_name.to_s.titleize %></span>
      </div>
    </div>

    <div class="divider"></div>

    <!-- AI Assistance Panel -->
    <div data-controller="ai">
      <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px;">
        <button class="ai-btn"
                data-action="click->ai#request"
                data-url="/ai/suggest_breakdown"
                data-params='{"issue_id": <%= @issue.id %>}'>
          ✦ Suggest Task Breakdown
        </button>
      </div>
      <div class="ai-panel" style="display: none;">
        <div class="ai-panel-header">✦ AI Suggestion</div>
        <div class="ai-response" data-ai-target="result"></div>
      </div>
    </div>

    <div class="divider"></div>

    <!-- Tasks Section -->
    <%= render 'tasks/tasks' %>

    <!-- Comments Section -->
    <%= render 'comments/comments' %>

    <!-- Back Link -->
    <p class="text-muted" style="margin-top: 16px;">
      <%= link_to "← Back to Board", board_path(@issue.board), class: "link" %>
    </p>
  </div>

  <!-- Sidebar -->
  <div style="border: 1.5px solid var(--wire); border-radius: 2px; padding: 16px; background: #faf8f4; height: fit-content;">
    <div style="font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--wire-dark); margin-bottom: 12px; display: flex; align-items: center; gap: 6px;">
      <span style="display: inline-block; width: 10px; height: 1.5px; background: var(--wire);"></span>
      Properties
    </div>

    <div style="margin-bottom: 16px;">
      <div style="font-size: 9px; color: var(--wire-dark); margin-bottom: 4px;">Status</div>
      <div style="font-size: 11px; font-weight: 600;"><%= @issue.status_name.to_s.titleize %></div>
    </div>

    <div style="margin-bottom: 16px;">
      <div style="font-size: 9px; color: var(--wire-dark); margin-bottom: 4px;">Assignee</div>
      <div style="font-size: 11px; font-weight: 600;"><%= @issue.user.name rescue "Unassigned" %></div>
    </div>

    <div style="margin-bottom: 16px;">
      <div style="font-size: 9px; color: var(--wire-dark); margin-bottom: 4px;">Created</div>
      <div style="font-size: 11px;"><%= @issue.created_at.strftime("%b %d, %Y") %></div>
    </div>

    <div style="border-top: 1px solid var(--wire); padding-top: 12px; margin-top: 12px;">
      <%= link_to "Change Status", edit_issue_path(@issue), class: "btn", style: "width: 100%; justify-content: center; margin-bottom: 8px;" %>
      <%= link_to "Edit Issue", edit_issue_path(@issue), class: "btn", style: "width: 100%; justify-content: center;" %>
    </div>
  </div>
</div>
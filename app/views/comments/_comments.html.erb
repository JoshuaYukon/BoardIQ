<div class="comments-section" style="margin-top: 40px; padding-top: 40px; border-top: 1px solid var(--wire);">
  <h3 style="margin-bottom: 20px;">Comments</h3>

  <div class="comments-list" style="margin-bottom: 30px;">
    <% @issue.comments.ordered.each do |comment| %>
      <div class="comment-card" style="padding: 16px; margin-bottom: 12px; background: var(--ghost); border-radius: 8px;">
        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 8px;">
          <div>
            <strong><%= comment.user&.name || 'Anonymous' %></strong>
            <span style="font-size: 12px; color: #999;">
              <%= time_ago_in_words(comment.created_at) %> ago
            </span>
          </div>
          <% if current_user&.id == comment.user_id %>
            <div style="display: flex; gap: 8px;">
              <%= link_to 'Edit', edit_issue_comment_path(@issue, comment), class: 'btn btn-sm' %>
              <%= link_to 'Delete', issue_comment_path(@issue, comment), data: { turbo_method: :delete, turbo_confirm: 'Sure?' }, class: 'btn btn-sm btn-danger' %>
            </div>
          <% end %>
        </div>
        <div class="comment-content">
          <%= simple_format(comment.content) %>
        </div>
      </div>
    <% end %>
  </div>

  <% if current_user %>
    <div class="new-comment-form" style="margin-top: 30px; padding: 20px; background: var(--ghost); border-radius: 8px;">
      <h4>Add a comment</h4>
      <form action="<%= issue_comments_path(@issue) %>" method="post" class="form" style="margin-top: 12px;">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        
        <div class="form-group">
          <textarea name="comment[content]" class="form-input" rows="4" placeholder="Write your comment here..." required></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Post Comment</button>
      </form>
    </div>
  <% else %>
    <p style="text-align: center; padding: 20px; color: #999;">
      <%= link_to 'Sign in', new_user_path %> to leave a comment
    </p>
  <% end %>
</div>

<div class="page-header">
  <h1>Edit Board State</h1>
</div>

<div style="max-width: 400px; margin: 40px auto;">
  <form action="<%= board_board_state_path(@board, @board_state) %>" method="post" class="form">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
    <input type="hidden" name="_method" value="patch">
    
    <div class="form-group">
      <label for="board_state_name">State Name</label>
      <input type="text" id="board_state_name" name="board_state[name]" value="<%= @board_state.name %>" required class="form-input">
    </div>

    <div class="form-group">
      <label for="board_state_color">Color</label>
      <input type="color" id="board_state_color" name="board_state[color]" value="<%= @board_state.color %>" class="form-input">
    </div>

    <button type="submit" class="btn btn-primary" style="width: 100%;">Update State</button>
  </form>
</div>

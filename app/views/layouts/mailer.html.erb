<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      body { font-family: -apple-system, sans-serif; color: #1a1a1a; background: #f5f5f0; margin: 0; padding: 0; }
      .container { max-width: 560px; margin: 40px auto; background: white; border: 1px solid #e0e0d8; border-radius: 4px; overflow: hidden; }
      .header { background: #1a1a1a; padding: 20px 32px; }
      .header .brand { color: white; font-size: 18px; font-weight: 700; letter-spacing: -0.5px; }
      .header .brand span { color: #d4541a; }
      .body { padding: 32px; }
      .footer { padding: 16px 32px; background: #f5f5f0; font-size: 11px; color: #999; border-top: 1px solid #e0e0d8; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <div class="brand">Board<span>IQ</span></div>
      </div>
      <div class="body">
        <%= yield %>
      </div>
      <div class="footer">
        You received this email because someone invited you to BoardIQ. If you didn't expect this, you can ignore it.
      </div>
    </div>
  </body>
</html>

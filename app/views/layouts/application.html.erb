<!DOCTYPE html>
<html>
  <head>
    <title>BoardIQ</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-layout">
      <!-- Sidebar -->
      <aside class="app-sidebar">
        <div class="sidebar-section" style="display: flex; justify-content: space-between; align-items: center;">
          <span>Projects</span>
          <%= link_to "+", new_project_path, style: "color: var(--wire-dark); text-decoration: none; font-size: 15px; line-height: 1; font-weight: 400;" %>
        </div>

        <% if @sidebar_projects&.any? %>
          <% @sidebar_projects.each do |project| %>
            <% has_active_sprint = project.sprints.any?(&:active?) %>
            <%= link_to project_path(project), class: "sidebar-item #{'active' if @current_project&.id == project.id}", style: "text-decoration: none; color: inherit;" do %>
              <div class="sidebar-item-icon" style="background: #d4541a;"></div>
              <span class="sidebar-item-text" style="flex: 1;"><%= project.name %></span>
              <% if has_active_sprint %>
                <span style="width: 7px; height: 7px; border-radius: 50%; background: #22c55e; flex-shrink: 0; margin-left: 4px;" title="Active sprint"></span>
              <% end %>
            <% end %>
          <% end %>
        <% else %>
          <div class="sidebar-item" style="opacity: 0.6;">
            <span class="sidebar-item-text">No projects yet</span>
          </div>
        <% end %>

        <div style="height: 1px; background: var(--wire); margin: 8px 0;"></div>

        <% if @current_project %>
          <div class="sidebar-section" style="display: flex; justify-content: space-between; align-items: center;">
            <span>Boards</span>
            <%= link_to "+", new_project_board_path(@current_project), style: "color: var(--wire-dark); text-decoration: none; font-size: 15px; line-height: 1; font-weight: 400;" %>
          </div>

          <% if @boards.any? %>
            <% @boards.each do |board| %>
              <%= link_to board_path(board), class: "sidebar-item #{'active' if current_page?(board_path(board))}", style: "text-decoration: none; color: inherit;" do %>
                <div class="sidebar-item-icon" style="background: #1d4e8f;"></div>
                <span class="sidebar-item-text"><%= board.name %></span>
              <% end %>
            <% end %>
          <% else %>
            <div class="sidebar-item" style="opacity: 0.6;">
              <div class="sidebar-item-icon"></div>
              <span class="sidebar-item-text">No boards yet</span>
            </div>
          <% end %>
        <% else %>
          <div class="sidebar-section">Boards</div>
          <div class="sidebar-item" style="opacity: 0.5;">
            <span class="sidebar-item-text" style="font-size: 10px;">Select a project</span>
          </div>
        <% end %>
      </aside>

      <!-- Main Content -->
      <div class="app-main">
        <!-- Topbar -->
        <header class="app-topbar">
          <div class="topbar-brand">Board<span>IQ</span></div>
          <div class="topbar-actions">
            <% if current_user %>
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="font-size: 12px; color: #999;"><%= current_user.name %></span>
                <% unread_count = current_user.notifications.unread.count %>
                <%= link_to notifications_path, class: "notif-bell" do %>
                  &#x1F514;
                  <% if unread_count > 0 %>
                    <span class="notif-badge"><%= unread_count %></span>
                  <% end %>
                <% end %>
                <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; cursor: pointer;" title="<%= current_user.email %>">
                  <%= current_user.name.first %>
                </div>
                <a href="<%= edit_user_path(current_user) %>" style="font-size: 12px; color: #666; text-decoration: none;">Settings</a>
                <%= button_to "Sign Out", sign_out_path, method: :delete, form: { style: "display: inline;" }, style: "background: none; border: none; font-size: 12px; color: #666; cursor: pointer; padding: 0;" %>
              </div>
            <% else %>
              <div style="display: flex; gap: 12px;">
                <%= link_to "Sign In", sign_in_path, class: "btn btn-primary" %>
                <%= link_to "Sign Up", new_user_path, class: "btn" %>
              </div>
            <% end %>
          </div>
        </header>

        <!-- Content -->
        <main class="app-content">
          <% if notice %>
            <div class="notice"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="alert"><%= alert %></div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>

    <!-- Confirm Modal -->
    <div id="confirm-modal" style="display:none; position:fixed; inset:0; z-index:1000; align-items:center; justify-content:center;">
      <div id="confirm-backdrop" style="position:absolute; inset:0; background:rgba(0,0,0,0.45);"></div>
      <div style="position:relative; background:var(--paper); border:1.5px solid var(--wire); border-radius:3px; padding:28px 28px 20px; width:360px; max-width:90vw; box-shadow:0 8px 32px rgba(0,0,0,0.18);">
        <div id="confirm-title" style="font-size:13px; font-weight:700; margin-bottom:8px; color:var(--ink);">Are you sure?</div>
        <div id="confirm-message" style="font-size:12px; color:var(--wire-dark); margin-bottom:24px; line-height:1.5;"></div>
        <div style="display:flex; gap:8px; justify-content:flex-end;">
          <button id="confirm-cancel" class="btn" style="font-size:11px;">Cancel</button>
          <button id="confirm-ok" class="btn" style="font-size:11px;">Confirm</button>
        </div>
      </div>
    </div>

  </body>
</html>